---
import JobCard from './JobCard.astro';
import { locationBuckets } from '../lib/locations';

interface Job {
  title: string;
  company: string;
  companyUrl: string;
  level: string;
  locationType: string;
  location: string;
  url: string;
  postedDate?: string | null;
  postedAt?: string | null;
  tags: string[];
  vertical?: string;
  employmentType?: string;
  salary?: string | null;
}

interface Props {
  jobs: Job[];
  /** Add data attributes for filtering (jobs page) */
  filterable?: boolean;
  /** Max stagger delay in ms */
  maxDelay?: number;
  /** Delay step per item in ms */
  delayStep?: number;
  id?: string;
}

const { jobs, filterable = false, maxDelay = 150, delayStep = 20, id } = Astro.props;
---

<!-- Masonry: CSS columns, tight gutters. Tiles flow top-to-bottom per column. -->
<ul
  class="columns-1 sm:columns-2 lg:columns-3 2xl:columns-4 gap-2.5 list-none"
  id={id}
  aria-label="Job listings"
>
  {jobs.map((job, i) => (
    <li
      class:list={["reveal reveal-fade break-inside-avoid mb-2.5", filterable && "job-item"]}
      data-delay={String(Math.min(i * delayStep, maxDelay))}
      {...(filterable ? {
        "data-level": job.level,
        "data-location-type": job.locationType,
        "data-location-buckets": locationBuckets(job.location, job.locationType).join('|'),
        "data-vertical": job.vertical || 'Healthcare',
        "data-employment-type": job.employmentType || 'Full-time',
        "data-search": `${job.title} ${job.company} ${job.location} ${job.vertical || ''} ${job.tags.join(' ')}`.toLowerCase(),
      } : {})}
    >
      <JobCard {...job} index={i} />
    </li>
  ))}
</ul>
