---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JobTable from '../components/JobTable.astro';
import Newsletter from '../components/Newsletter.astro';
import jobs from '../data/jobs.json';

const featuredJobs = [...jobs].sort((a, b) => {
  if (!a.postedAt && !b.postedAt) return 0;
  if (!a.postedAt) return 1;
  if (!b.postedAt) return -1;
  return b.postedAt.localeCompare(a.postedAt);
}).slice(0, 18);

const contractCount = jobs.filter(j => j.employmentType === 'Contract' || j.employmentType === 'Freelance').length;
---

<Layout title="designjobs.cv — Design jobs, verified">
  <Header />

  <main id="main-content" tabindex="-1">

  <!-- JSON-LD: Website structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "designjobs.cv",
    "url": "https://designjobs.cv",
    "description": "Design jobs at startups across healthcare, AI, and unexpected verticals. Full-time and contract, every listing verified.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://designjobs.cv/jobs?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- Statement — the page opens like a gallery wall label, then the work -->
  <section class="w-full max-w-[1800px] mx-auto px-4 md:px-6 pt-16 md:pt-24 pb-12 md:pb-16">
    <h1 class="animate-fade-up stagger-1 font-display font-semibold text-[2.6rem] md:text-7xl leading-[0.98] tracking-tight [text-wrap:balance] max-w-4xl">
      Design work worth&nbsp;doing.
    </h1>
    <div class="animate-fade-up stagger-2 mt-6 md:mt-8 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <p class="text-base md:text-lg text-muted dark:text-slate-400 leading-relaxed max-w-md">
        A community-curated board of design roles at startups — healthcare, AI, and the verticals nobody's watching. Every link goes to the real posting.
      </p>
      <div class="flex items-center gap-2.5 shrink-0">
        <a href="/jobs" class="px-5 py-2.5 rounded-full bg-ink text-paper dark:bg-slate-100 dark:text-ink text-sm font-medium hover:opacity-85 transition-opacity" data-umami-event="hero-alljobs-click">
          {jobs.length} open roles
        </a>
        <a href="/jobs?type=Contract" class="px-5 py-2.5 rounded-full border border-ink dark:border-slate-300 text-ink dark:text-slate-100 text-sm font-medium hover:bg-ink hover:text-paper dark:hover:bg-slate-100 dark:hover:text-ink transition-colors" data-umami-event="hero-contract-click">
          Contract{contractCount > 0 ? ` (${contractCount})` : ''}
        </a>
      </div>
    </div>
  </section>

  <!-- The wall: latest roles as typographic tiles -->
  <section class="w-full max-w-[1800px] mx-auto px-4 md:px-6 pb-16">
    <h2 class="sr-only">Latest roles</h2>
    <JobTable jobs={featuredJobs} maxDelay={200} />
    <div class="reveal text-center mt-10" data-delay="100">
      <a
        href="/jobs"
        class="inline-flex px-7 py-3 rounded-full border border-ink dark:border-slate-300 text-ink dark:text-slate-100 font-medium text-sm hover:bg-ink hover:text-paper dark:hover:bg-slate-100 dark:hover:text-ink transition-colors"
        data-umami-event="home-viewall-click"
      >
        View all {jobs.length} jobs →
      </a>
    </div>
  </section>

  <!-- Why this board exists — quiet, three lines, no icon cards -->
  <section class="w-full max-w-[1800px] mx-auto px-4 md:px-6 pb-16">
    <div class="border-t border-line dark:border-slate-700/50 pt-12 grid md:grid-cols-3 gap-10 md:gap-14 max-w-5xl mx-auto text-center">
      <div class="reveal" data-delay="0">
        <h3 class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted dark:text-slate-500 mb-2">No ghost jobs</h3>
        <p class="text-sm text-ink-soft dark:text-slate-300 leading-relaxed">Every listing is browser-verified before it's published, and re-checked while it's live. If it's here, it's real.</p>
      </div>
      <div class="reveal" data-delay="60">
        <h3 class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted dark:text-slate-500 mb-2">Real links only</h3>
        <p class="text-sm text-ink-soft dark:text-slate-300 leading-relaxed">Straight to the company's own posting — never a LinkedIn wall, never an aggregator loop.</p>
      </div>
      <div class="reveal" data-delay="120">
        <h3 class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted dark:text-slate-500 mb-2">Community-built</h3>
        <p class="text-sm text-ink-soft dark:text-slate-300 leading-relaxed">Open source, free forever. Anyone can submit a role, flag an issue, or improve the code.</p>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="w-full max-w-[1800px] mx-auto px-4 md:px-6 pb-12">
    <div class="reveal" data-delay="0">
      <Newsletter />
    </div>
  </section>

  </main>

  <Footer />
</Layout>
