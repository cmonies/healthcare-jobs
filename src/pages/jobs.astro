---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JobTable from '../components/JobTable.astro';
import jobs from '../data/jobs.json';
import { allLocationBuckets } from '../lib/locations';

const sortedJobs = [...jobs].sort((a, b) => {
  if (!a.postedAt && !b.postedAt) return 0;
  if (!a.postedAt) return 1;
  if (!b.postedAt) return -1;
  return b.postedAt.localeCompare(a.postedAt);
});

const levelOrder = ['Entry', 'Junior', 'Mid', 'Mid-Senior', 'Senior', 'Staff', 'Lead', 'Principal', 'Manager', 'Director'];
const levels = levelOrder.filter(l => jobs.some(j => j.level === l));
const locationTypes = [...new Set(jobs.map(j => j.locationType))];
const locations = allLocationBuckets(jobs);
const verticals = [...new Set(jobs.map(j => j.vertical || 'Healthcare'))].sort();

const levelCounts: Record<string, number> = {};
levels.forEach(l => { levelCounts[l] = jobs.filter(j => j.level === l).length; });
const locationCounts: Record<string, number> = {};
locationTypes.forEach(lt => { locationCounts[lt] = jobs.filter(j => j.locationType === lt).length; });
const verticalCounts: Record<string, number> = {};
verticals.forEach(v => { verticalCounts[v] = jobs.filter(j => (j.vertical || 'Healthcare') === v).length; });

const fullTimeCount = jobs.filter(j => (j.employmentType || 'Full-time') === 'Full-time').length;
const contractCount = jobs.filter(j => j.employmentType === 'Contract' || j.employmentType === 'Freelance').length;
const employmentOptions = [
  { value: 'Full-time', count: fullTimeCount },
  { value: 'Contract', count: contractCount },
];
---

<Layout title="All jobs — designjobs.cv" description="Browse open design roles at startups across healthcare, AI, and unexpected verticals. Full-time and contract — every listing verified against the company's real posting.">
  <Header />

  <main id="main-content" tabindex="-1">

  <!-- JSON-LD: JobPosting structured data for search engines -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Design Jobs",
    "description": "Curated design roles at startups — verified listings, full-time and contract",
    "numberOfItems": jobs.length,
    "itemListElement": jobs.slice(0, 50).map((job, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "JobPosting",
        "title": job.title,
        "datePosted": job.postedAt || job.postedDate,
        "hiringOrganization": {
          "@type": "Organization",
          "name": job.company,
          "sameAs": job.companyUrl
        },
        "jobLocation": {
          "@type": "Place",
          "address": job.locationType === 'Remote' ? { "@type": "PostalAddress", "addressCountry": "US" } : { "@type": "PostalAddress", "addressLocality": job.location }
        },
        "jobLocationType": job.locationType === 'Remote' ? "TELECOMMUTE" : undefined,
        "url": job.url,
        "employmentType": (job.employmentType === 'Contract' || job.employmentType === 'Freelance') ? "CONTRACTOR" : "FULL_TIME"
      }
    }))
  })} />

  <section class="w-full max-w-[1800px] mx-auto px-4 md:px-6 pt-12 pb-6">
    <h1 class="animate-fade-in stagger-1 font-display text-3xl md:text-4xl font-semibold tracking-tight mb-2">All jobs</h1>
    <p class="animate-fade-in stagger-1 text-base text-muted dark:text-slate-400"><span id="visible-count">{jobs.length}</span> <span id="count-label">design roles currently open</span></p>
  </section>

  <!-- Search + filter row: one cohesive bar; selections become dismissible pills below -->
  <section class="w-full max-w-[1800px] mx-auto px-4 md:px-6 pb-4 relative z-10" role="search" aria-label="Search and filter jobs">
    <div class="animate-fade-in stagger-2 flex flex-col sm:flex-row sm:flex-wrap gap-2.5">
      <!-- Search -->
      <div class="relative flex-1 min-w-[220px]">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" />
        </svg>
        <input
          id="search-input"
          type="text"
          aria-label="Search jobs by title, company, location, or tag"
          placeholder="Search by title, company, or tag..."
          class="w-full pl-11 pr-10 py-3 rounded-full border border-line dark:border-slate-700 bg-paper dark:bg-surface-card text-base md:text-sm text-ink dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:border-ink dark:focus:border-slate-400 transition-[border-color] duration-150"
        />
        <button id="search-clear" class="hidden absolute right-2 top-1/2 -translate-y-1/2 p-1.5 text-slate-400 hover:text-ink dark:hover:text-slate-200 transition-colors" aria-label="Clear search" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18" /><path d="m6 6 12 12" />
          </svg>
        </button>
      </div>

      <!-- Location dropdown (native select) -->
      <div class="relative sm:w-44">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" />
        </svg>
        <select
          id="location-select"
          aria-label="Filter by location"
          class="w-full appearance-none pl-9 pr-8 py-3 rounded-full border border-line dark:border-slate-700 bg-paper dark:bg-surface-card text-base md:text-sm text-ink dark:text-slate-100 focus:outline-none focus:border-ink dark:focus:border-slate-400 transition-[border-color] duration-150 cursor-pointer"
        >
          <option value="">All locations</option>
          {locations.map(loc => (
            <option value={loc}>{loc}</option>
          ))}
        </select>
        <svg class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="m6 9 6 6 6-6" />
        </svg>
      </div>

      <!-- Category dropdown -->
      <div class="relative dj-dropdown" data-dropdown="category">
        <button
          type="button"
          class="dj-dropdown-btn flex items-center gap-2 px-4 py-3 rounded-full border border-line dark:border-slate-700 bg-paper dark:bg-surface-card text-sm font-medium text-ink-soft dark:text-slate-300 hover:border-ink dark:hover:border-slate-400 transition-[border-color] duration-150 cursor-pointer whitespace-nowrap"
          aria-expanded="false"
          aria-haspopup="true"
        >
          Category
          <span class="dj-badge hidden text-xs bg-ink text-paper dark:bg-slate-100 dark:text-ink rounded-full w-5 h-5 inline-flex items-center justify-center font-semibold">0</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m6 9 6 6 6-6" /></svg>
        </button>
        <div class="dj-dropdown-panel hidden absolute right-0 top-full mt-2 w-64 bg-paper dark:bg-surface-card border border-line dark:border-slate-700 rounded-2xl shadow-soft-lg z-50 overflow-hidden">
          <div class="p-4 space-y-1.5">
            {verticals.map(v => (
              <label class="flex items-center gap-3 cursor-pointer py-1 px-2 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                <input type="checkbox" class="filter-checkbox rounded border-slate-300 dark:border-slate-600 text-ink focus:ring-slate-400" data-type="vertical" data-value={v} />
                <span class="text-sm text-ink-soft dark:text-slate-300 flex-1">{v}</span>
                <span class="text-xs text-slate-500 dark:text-slate-400">{verticalCounts[v]}</span>
              </label>
            ))}
          </div>
        </div>
      </div>

      <!-- Type dropdown -->
      <div class="relative dj-dropdown" data-dropdown="type">
        <button
          type="button"
          class="dj-dropdown-btn flex items-center gap-2 px-4 py-3 rounded-full border border-line dark:border-slate-700 bg-paper dark:bg-surface-card text-sm font-medium text-ink-soft dark:text-slate-300 hover:border-ink dark:hover:border-slate-400 transition-[border-color] duration-150 cursor-pointer whitespace-nowrap"
          aria-expanded="false"
          aria-haspopup="true"
        >
          Type
          <span class="dj-badge hidden text-xs bg-ink text-paper dark:bg-slate-100 dark:text-ink rounded-full w-5 h-5 inline-flex items-center justify-center font-semibold">0</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m6 9 6 6 6-6" /></svg>
        </button>
        <div class="dj-dropdown-panel hidden absolute right-0 top-full mt-2 w-56 bg-paper dark:bg-surface-card border border-line dark:border-slate-700 rounded-2xl shadow-soft-lg z-50 overflow-hidden">
          <div class="p-4 space-y-1.5">
            {employmentOptions.map(opt => (
              <label class="flex items-center gap-3 cursor-pointer py-1 px-2 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                <input type="checkbox" class="filter-checkbox rounded border-slate-300 dark:border-slate-600 text-ink focus:ring-slate-400" data-type="employment" data-value={opt.value} />
                <span class="text-sm text-ink-soft dark:text-slate-300 flex-1">{opt.value}</span>
                <span class="text-xs text-slate-500 dark:text-slate-400">{opt.count}</span>
              </label>
            ))}
          </div>
        </div>
      </div>

      <!-- Filters dropdown (level + work type) -->
      <div class="relative dj-dropdown" data-dropdown="more">
        <button
          type="button"
          class="dj-dropdown-btn flex items-center gap-2 px-4 py-3 rounded-full border border-line dark:border-slate-700 bg-paper dark:bg-surface-card text-sm font-medium text-ink-soft dark:text-slate-300 hover:border-ink dark:hover:border-slate-400 transition-[border-color] duration-150 cursor-pointer whitespace-nowrap"
          aria-expanded="false"
          aria-haspopup="true"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="4" y1="6" x2="20" y2="6" /><line x1="8" y1="12" x2="16" y2="12" /><line x1="11" y1="18" x2="13" y2="18" />
          </svg>
          Filters
          <span class="dj-badge hidden text-xs bg-ink text-paper dark:bg-slate-100 dark:text-ink rounded-full w-5 h-5 inline-flex items-center justify-center font-semibold">0</span>
        </button>
        <div class="dj-dropdown-panel hidden absolute right-0 top-full mt-2 w-72 bg-paper dark:bg-surface-card border border-line dark:border-slate-700 rounded-2xl shadow-soft-lg z-50 overflow-hidden">
          <div class="p-4 space-y-4">
            <div>
              <p class="font-mono text-[11px] font-semibold text-muted dark:text-slate-500 uppercase tracking-[0.14em] mb-2">Level</p>
              <div class="space-y-1.5">
                {levels.map(level => (
                  <label class="flex items-center gap-3 cursor-pointer py-1 px-2 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                    <input type="checkbox" class="filter-checkbox rounded border-slate-300 dark:border-slate-600 text-ink focus:ring-slate-400" data-type="level" data-value={level} />
                    <span class="text-sm text-ink-soft dark:text-slate-300 flex-1">{level}</span>
                    <span class="text-xs text-slate-500 dark:text-slate-400">{levelCounts[level]}</span>
                  </label>
                ))}
              </div>
            </div>
            <div class="border-t border-line dark:border-slate-700/50 pt-4">
              <p class="font-mono text-[11px] font-semibold text-muted dark:text-slate-500 uppercase tracking-[0.14em] mb-2">Work type</p>
              <div class="space-y-1.5">
                {locationTypes.map(lt => (
                  <label class="flex items-center gap-3 cursor-pointer py-1 px-2 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                    <input type="checkbox" class="filter-checkbox rounded border-slate-300 dark:border-slate-600 text-ink focus:ring-slate-400" data-type="locationType" data-value={lt} />
                    <span class="text-sm text-ink-soft dark:text-slate-300 flex-1">{lt}</span>
                    <span class="text-xs text-slate-500 dark:text-slate-400">{locationCounts[lt]}</span>
                  </label>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Active filter pills (selections from any dropdown land here, dismissible) -->
    <div id="active-filters" class="hidden flex flex-wrap items-center gap-2 mt-3">
      <span class="text-xs text-slate-500 dark:text-slate-400">Filtered by:</span>
      <div id="active-pills" class="flex flex-wrap gap-1.5"></div>
      <button id="clear-filters" class="text-xs text-ink dark:text-slate-200 hover:underline font-medium ml-1 transition-colors">Clear all</button>
    </div>
  </section>

  <!-- Jobs wall -->
  <section class="w-full max-w-[1800px] mx-auto px-4 md:px-6 pb-20">
    <h2 class="sr-only">Open roles</h2>
    <JobTable jobs={sortedJobs} filterable id="jobs-list" delayStep={30} />
    <div id="no-results" class="text-center py-12 hidden">
      <p class="text-slate-400 mb-4">No jobs match your current filters.</p>
      <button id="clear-all-filters" class="px-5 py-2.5 text-sm font-medium text-ink-soft dark:text-slate-300 bg-transparent border border-line dark:border-slate-700 rounded-full hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
        Clear all filters
      </button>
    </div>
  </section>


  </main>

  <Footer />
</Layout>

<style is:global>
  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3rem 0.5rem 0.3rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    border: 1px solid #EAE8E2;
    background: white;
    color: #3C3A34;
    cursor: pointer;
    transition: border-color 0.15s ease, background-color 0.15s ease;
    white-space: nowrap;
  }
  .filter-pill:hover {
    border-color: #161512;
    background: #F5F4F1;
  }
  .dark .filter-pill {
    border-color: #26251F;
    background: #181816;
    color: #A3A099;
  }
  .dark .filter-pill:hover {
    border-color: #A3A099;
    background: #1F1E1A;
  }
  .filter-pill .pill-x {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    border-radius: 9999px;
    background: #EAE8E2;
    color: #77746B;
    font-size: 0.625rem;
    line-height: 1;
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .filter-pill:hover .pill-x {
    background: #161512;
    color: white;
  }
  .dark .filter-pill .pill-x {
    background: #26251F;
    color: #A3A099;
  }
  .dark .filter-pill:hover .pill-x {
    background: #F1F0EC;
    color: #161512;
  }
</style>

<script>
  const items = document.querySelectorAll('.job-item');
  const noResults = document.getElementById('no-results');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchClear = document.getElementById('search-clear');
  const locationSelect = document.getElementById('location-select') as HTMLSelectElement;
  const visibleCount = document.getElementById('visible-count');
  const activeFiltersContainer = document.getElementById('active-filters');
  const activePills = document.getElementById('active-pills');
  const clearFilters = document.getElementById('clear-filters');
  const checkboxes = document.querySelectorAll('.filter-checkbox') as NodeListOf<HTMLInputElement>;
  const dropdowns = document.querySelectorAll('.dj-dropdown') as NodeListOf<HTMLElement>;

  // Restore saved filters (with migration from the old single-value shape)
  const saved = JSON.parse(localStorage.getItem('dj-filters') || '{}');
  let searchQuery = saved.search || '';
  let activeLocation = saved.location || '';
  const sets: Record<string, Set<string>> = {
    vertical: new Set(saved.verticals || (saved.vertical ? [saved.vertical] : [])),
    employment: new Set(saved.employments || (saved.employment ? [saved.employment] : [])),
    level: new Set(saved.levels || []),
    locationType: new Set(saved.locationTypes || []),
  };

  // URL params take precedence: /jobs?type=Contract, /jobs?category=AI
  const params = new URLSearchParams(window.location.search);
  const urlType = params.get('type');
  if (urlType === 'Contract' || urlType === 'Full-time') sets.employment.add(urlType);
  const urlCategory = params.get('category');
  if (urlCategory) sets.vertical.add(urlCategory);

  function saveFilters() {
    localStorage.setItem('dj-filters', JSON.stringify({
      search: searchQuery,
      location: activeLocation,
      verticals: [...sets.vertical],
      employments: [...sets.employment],
      levels: [...sets.level],
      locationTypes: [...sets.locationType],
    }));
  }

  // Which dropdown owns which filter types (drives the per-button badge)
  const dropdownTypes: Record<string, string[]> = {
    category: ['vertical'],
    type: ['employment'],
    more: ['level', 'locationType'],
  };

  // Generic dropdown open/close — one open at a time
  function closeAllDropdowns(except?: HTMLElement) {
    dropdowns.forEach(dd => {
      if (dd === except) return;
      dd.querySelector('.dj-dropdown-panel')?.classList.add('hidden');
      dd.querySelector('.dj-dropdown-btn')?.setAttribute('aria-expanded', 'false');
    });
  }

  dropdowns.forEach(dd => {
    const btn = dd.querySelector('.dj-dropdown-btn');
    const panel = dd.querySelector('.dj-dropdown-panel');
    btn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const willOpen = panel?.classList.contains('hidden');
      closeAllDropdowns(dd);
      panel?.classList.toggle('hidden');
      btn?.setAttribute('aria-expanded', String(willOpen));
    });
  });

  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    const insideAny = [...dropdowns].some(dd => dd.contains(target));
    if (!insideAny) closeAllDropdowns();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAllDropdowns();
  });

  // Restore UI state from saved filters
  if (searchInput && searchQuery) { searchInput.value = searchQuery; searchClear?.classList.remove('hidden'); }
  if (locationSelect && activeLocation) locationSelect.value = activeLocation;
  checkboxes.forEach(cb => {
    const type = cb.dataset.type || '';
    const value = cb.dataset.value || '';
    if (sets[type]?.has(value)) cb.checked = true;
  });
  const anyActive = searchQuery || activeLocation || Object.values(sets).some(s => s.size);
  if (anyActive) {
    requestAnimationFrame(() => { updatePills(); applyFilters(); });
  }

  // One handler for every checkbox filter (vertical, employment, level, locationType)
  checkboxes.forEach(cb => {
    cb.addEventListener('change', () => {
      const type = cb.dataset.type || '';
      const value = cb.dataset.value || '';
      if (!sets[type]) return;
      cb.checked ? sets[type].add(value) : sets[type].delete(value);
      updatePills();
      applyFilters();
      saveFilters();
    });
  });

  clearFilters?.addEventListener('click', () => {
    Object.values(sets).forEach(s => s.clear());
    checkboxes.forEach(cb => cb.checked = false);
    updatePills();
    applyFilters();
    saveFilters();
  });

  function updatePills() {
    if (!activePills || !activeFiltersContainer) return;

    activePills.innerHTML = '';
    const totalFilters = Object.values(sets).reduce((n, s) => n + s.size, 0);
    activeFiltersContainer.classList.toggle('hidden', totalFilters === 0);

    // Per-dropdown badges
    dropdowns.forEach(dd => {
      const key = dd.dataset.dropdown || '';
      const badge = dd.querySelector('.dj-badge');
      if (!badge) return;
      const count = (dropdownTypes[key] || []).reduce((n, t) => n + sets[t].size, 0);
      badge.textContent = String(count);
      badge.classList.toggle('hidden', count === 0);
    });

    const createPill = (label: string, type: string, value: string) => {
      const pill = document.createElement('button');
      pill.className = 'filter-pill';
      pill.setAttribute('aria-label', `Remove filter: ${label}`);
      pill.innerHTML = `${label}<span class="pill-x">✕</span>`;
      pill.addEventListener('click', () => {
        sets[type].delete(value);
        checkboxes.forEach(cb => {
          if (cb.dataset.type === type && cb.dataset.value === value) cb.checked = false;
        });
        updatePills();
        applyFilters();
        saveFilters();
      });
      return pill;
    };

    sets.vertical.forEach(v => activePills!.appendChild(createPill(v, 'vertical', v)));
    sets.employment.forEach(v => activePills!.appendChild(createPill(v, 'employment', v)));
    sets.level.forEach(v => activePills!.appendChild(createPill(v, 'level', v)));
    sets.locationType.forEach(v => activePills!.appendChild(createPill(v, 'locationType', v)));
  }

  let settleTimer: ReturnType<typeof setTimeout> | undefined;
  function applyFilters() {
    // Mask the columns reflow with a quick settle fade (GPU-only, opacity)
    const list = document.getElementById('jobs-list');
    if (list) {
      list.classList.remove('filter-settle');
      list.classList.add('filtering');
      clearTimeout(settleTimer);
      settleTimer = setTimeout(() => {
        list.classList.remove('filtering');
        list.classList.add('filter-settle');
      }, 80);
    }
    let visible = 0;
    items.forEach(item => {
      const el = item as HTMLElement;
      let show = true;

      // Category multi-select
      if (sets.vertical.size > 0) {
        show = sets.vertical.has(el.dataset.vertical || 'Healthcare');
      }

      // Employment multi-select (Contract also matches Freelance)
      if (show && sets.employment.size > 0) {
        const emp = el.dataset.employmentType || 'Full-time';
        show = sets.employment.has(emp) || (sets.employment.has('Contract') && emp === 'Freelance');
      }

      // Level multi-select
      if (show && sets.level.size > 0) {
        show = sets.level.has(el.dataset.level || '');
      }

      // Location type multi-select
      if (show && sets.locationType.size > 0) {
        show = sets.locationType.has(el.dataset.locationType || '');
      }

      // Location dropdown — matches any of the job's normalized buckets
      if (show && activeLocation) {
        show = (el.dataset.locationBuckets || '').split('|').includes(activeLocation);
      }

      // Search
      if (show && searchQuery) {
        show = (el.dataset.search || '').includes(searchQuery);
      }

      el.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (noResults) noResults.classList.toggle('hidden', visible > 0);
    if (visibleCount) visibleCount.textContent = String(visible);
    const countLabel = document.getElementById('count-label');
    const filtered = visible !== items.length;
    if (countLabel) countLabel.textContent = filtered ? `of ${items.length} design roles shown` : 'design roles currently open';
  }

  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value.toLowerCase().trim();
    searchClear?.classList.toggle('hidden', !searchQuery);
    applyFilters();
    saveFilters();
  });

  document.getElementById('clear-all-filters')?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    if (locationSelect) locationSelect.value = '';
    searchQuery = '';
    activeLocation = '';
    Object.values(sets).forEach(s => s.clear());
    checkboxes.forEach(cb => cb.checked = false);
    searchClear?.classList.add('hidden');
    updatePills();
    applyFilters();
    saveFilters();
  });

  searchClear?.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    if (searchInput) { searchInput.value = ''; searchInput.focus(); }
    searchQuery = '';
    searchClear!.classList.add('hidden');
    applyFilters();
    saveFilters();
  });

  locationSelect?.addEventListener('change', () => {
    activeLocation = locationSelect.value;
    applyFilters();
    saveFilters();
  });
</script>
