---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import jobs from '../../data/jobs.json';
import jobDetails from '../../data/job-details.json';
import jobContacts from '../../data/job-contacts.json';
import jobFeedbackData from '../../data/job-feedback.json';
import { computeGrade, gradeColorKey, MIN_REPORTS_FOR_GRADE } from '../../lib/grades';

export function getStaticPaths() {
  return jobs
    .filter((job): job is typeof job & { id: string } => !!job.id)
    .map(job => ({
      params: { id: job.id },
      props: { job },
    }));
}

const { job } = Astro.props;
const {
  id, title, company, companyUrl, url, level, locationType, location,
  postedAt, tags = [], vertical, employmentType = 'Full-time', salary,
  interviewProcess = null,
} = job;

const details = (jobDetails as Record<string, { descriptionHtml: string; salaryText: string | null; source: string; fetchedAt: string }>)[id] ?? null;

type Contact = { name: string; title: string; linkedinUrl: string; role: string; source: string; verifiedAt: string };
const contacts = ((jobContacts as Record<string, Contact[]>)[id] ?? []).slice(0, 3);
const roleLabel: Record<string, string> = {
  'founder': 'Founder',
  'recruiter': 'Recruiter',
  'design-leader': 'Design lead',
};
const sentence = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);

type Anecdote = { text: string; source: string; date?: string };
const MONTHS: Record<string, number> = { jan: 1, feb: 2, mar: 3, apr: 4, may: 5, jun: 6, jul: 7, aug: 8, sep: 9, oct: 10, nov: 11, dec: 12 };
const anecdoteKey = (a: Anecdote) => {
  const m = /([a-z]{3})[a-z]*\s+(\d{4})/i.exec(a.date || '');
  return m ? parseInt(m[2], 10) * 100 + (MONTHS[m[1].toLowerCase()] || 0) : 0;
};
// most recent first — recency is the ranking until we collect helpfulness votes
const anecdotes: Anecdote[] = ((interviewProcess?.anecdotes as Anecdote[]) || [])
  .slice()
  .sort((a, b) => anecdoteKey(b) - anecdoteKey(a));
const salaryDisplay = salary || details?.salaryText || null;

const feedbackEntry = (jobFeedbackData as Record<string, { reports: any[] }>)[id] ?? null;
const gradeResult = feedbackEntry?.reports?.length ? computeGrade(feedbackEntry.reports) : null;
const gradeColorClass = gradeResult?.hasEnoughData ? gradeColorKey(gradeResult.grade) : null;
const feedbackUrl = `/feedback?job=${encodeURIComponent(id)}&company=${encodeURIComponent(company)}&title=${encodeURIComponent(title)}`;
const gradeRows = gradeResult?.hasEnoughData ? [
  { label: 'Communication', pts: gradeResult.breakdown.communication, max: 30 },
  { label: 'Respect for time', pts: gradeResult.breakdown.respectForTime, max: 25 },
  { label: 'Transparency', pts: gradeResult.breakdown.transparency, max: 20 },
  { label: 'Interviewer quality', pts: gradeResult.breakdown.interviewerQuality, max: 15 },
  { label: 'Community rating', pts: gradeResult.breakdown.overall, max: 10 },
] : [];

const isContract = employmentType === 'Contract' || employmentType === 'Freelance';
const locationStr = locationType === 'Remote'
  ? 'Remote'
  : location ? `${locationType} — ${location}` : locationType;

const pageTitle = `${title} at ${company} | designjobs.cv`;
const description = `${level} ${title} at ${company}. ${employmentType}, ${locationStr}. Verified listing on designjobs.cv — the community design jobs board.`;

const atsDomain = (() => {
  try { return new URL(url).hostname.replace('www.', ''); }
  catch { return 'company careers page'; }
})();

const daysAgo = postedAt
  ? Math.floor((Date.now() - new Date(postedAt + 'T12:00:00').getTime()) / 86400000)
  : null;

const freshnessLabel = (() => {
  if (daysAgo === null) return null;
  if (daysAgo === 0) return 'Posted today';
  if (daysAgo === 1) return 'Posted yesterday';
  if (daysAgo < 7) return `Posted ${daysAgo} days ago`;
  if (daysAgo < 14) return 'Posted 1 week ago';
  if (daysAgo < 21) return 'Posted 2 weeks ago';
  if (daysAgo < 30) return 'Posted 3 weeks ago';
  return `Posted ${daysAgo} days ago`;
})();

const isStale = daysAgo !== null && daysAgo >= 21;
const isVeryStale = daysAgo !== null && daysAgo >= 30;

const reportUrl = `/report?category=dead-link&job=${encodeURIComponent(id)}&url=${encodeURIComponent(url)}`;

const descriptionPlain = details
  ? details.descriptionHtml.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 5000)
  : null;

const jobPostingSchema = {
  "@context": "https://schema.org",
  "@type": "JobPosting",
  "title": title,
  "datePosted": postedAt || new Date().toISOString().split('T')[0],
  ...(descriptionPlain ? { "description": descriptionPlain } : {}),
  "hiringOrganization": {
    "@type": "Organization",
    "name": company,
    "sameAs": companyUrl,
  },
  "jobLocation": {
    "@type": "Place",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "US",
      ...(locationType !== 'Remote' && location ? { "addressLocality": location } : {}),
    },
  },
  ...(locationType === 'Remote' ? {
    "jobLocationType": "TELECOMMUTE",
    "applicantLocationRequirements": { "@type": "Country", "name": "United States" },
  } : {}),
  "employmentType": isContract ? "CONTRACTOR" : "FULL_TIME",
  "url": `https://designjobs.cv/jobs/${id}`,
  "directApply": false,
  ...(salaryDisplay ? { "baseSalary": { "@type": "MonetaryAmount", "description": salaryDisplay } } : {}),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "designjobs.cv", "item": "https://designjobs.cv" },
    { "@type": "ListItem", "position": 2, "name": "All jobs", "item": "https://designjobs.cv/jobs" },
    { "@type": "ListItem", "position": 3, "name": `${title} at ${company}`, "item": `https://designjobs.cv/jobs/${id}` },
  ],
};

---

<Layout title={pageTitle} description={description}>
  <Header />

  <main id="main-content" tabindex="-1">

    <!-- Sticky section nav — slides in after scrolling past the page header -->
    <nav
      id="section-nav"
      aria-label="Page sections"
      class="fixed inset-x-0 top-0 z-[60] bg-paper/95 dark:bg-surface-header/95 backdrop-blur-xl border-b border-line dark:border-slate-700/50 -translate-y-full opacity-0 pointer-events-none transition-[transform,opacity] duration-200 ease-out motion-reduce:transition-none"
    >
      <div class="w-full max-w-6xl mx-auto px-4 md:px-6 h-full min-h-14 flex items-center justify-between gap-4">
        <button type="button" id="nav-to-top" class="group min-w-0 flex items-baseline gap-2.5 text-left cursor-pointer" aria-label="Back to top">
          <span class="truncate text-[15px] font-semibold text-ink dark:text-slate-100 group-hover:opacity-75 transition-opacity">{title}</span>
          <span class="hidden sm:inline font-mono text-[11px] uppercase tracking-[0.12em] text-muted dark:text-slate-400 shrink-0">{company}</span>
        </button>
        <div class="flex items-center gap-4 shrink-0">
          {salaryDisplay && (
            <span class="hidden md:block font-mono text-[11px] text-muted dark:text-slate-400 whitespace-nowrap">{salaryDisplay}</span>
          )}
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            data-apply-tracking={id}
            class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-ink text-paper dark:bg-slate-100 dark:text-ink text-[13px] font-semibold hover:opacity-85 transition-opacity whitespace-nowrap"
          >
            Apply
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
        </div>
      </div>
    </nav>
    <script type="application/ld+json" set:html={JSON.stringify(jobPostingSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <div class="hidden md:block w-full max-w-6xl mx-auto px-4 md:px-6 pt-6 pb-0">
      <nav aria-label="Breadcrumb" class="animate-fade-in stagger-1">
        <a href="/jobs" class="inline-flex items-center gap-1.5 text-sm text-muted dark:text-slate-400 hover:text-ink dark:hover:text-white transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6" />
          </svg>
          All design jobs
        </a>
      </nav>
    </div>

    <section class="w-full max-w-6xl mx-auto px-4 md:px-6 pt-6 pb-28">

      <!-- Page header: title block left, apply action right -->
      <header id="overview" class="scroll-mt-20 animate-fade-up stagger-1 flex flex-col md:flex-row md:items-end md:justify-between gap-6 pb-0 lg:pb-8 border-b-0 lg:border-b border-line dark:border-slate-700/50">
        <div class="min-w-0">
          <div class="flex items-center gap-3 mb-4">
            <a href={companyUrl} target="_blank" rel="noopener noreferrer" class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted dark:text-slate-400 hover:text-ink dark:hover:text-white transition-colors">
              {company}
            </a>
            {isContract && (
              <span class="font-mono text-[10px] uppercase tracking-[0.12em] font-bold px-2.5 py-1 rounded-full bg-tile-ink text-[#F2F1EC] dark:bg-[#EDEBE4] dark:text-ink">
                Contract
              </span>
            )}
          </div>

          <h1 class="font-display font-semibold text-[2rem] md:text-[2.75rem] leading-[1.04] tracking-tight [text-wrap:balance] mb-4">
            {title}
          </h1>

          <div class="flex flex-wrap gap-x-5 gap-y-1.5 font-mono text-[11px] uppercase tracking-[0.1em] text-muted dark:text-slate-400">
            <span>{level}</span>
            <span>{employmentType}</span>
            <span>{locationStr}</span>
            {vertical && <span>{vertical}</span>}
            {freshnessLabel && (
              <span class:list={[
                isVeryStale ? 'text-amber-500 dark:text-amber-400' :
                isStale     ? 'text-amber-500/70 dark:text-amber-400/70' :
                              'text-muted dark:text-slate-400'
              ]}>
                {freshnessLabel}
              </span>
            )}
          </div>

          {salaryDisplay && (
            <p class="font-mono text-sm text-ink-soft dark:text-slate-300 mt-3">{salaryDisplay}</p>
          )}

          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-5">
              {tags.map(tag => (
                <span class="px-3 py-1 rounded-full border border-line dark:border-slate-700 text-xs text-ink-soft dark:text-slate-300 font-mono">
                  {sentence(tag)}
                </span>
              ))}
            </div>
          )}
        </div>

        <div class="shrink-0 flex flex-col md:items-end gap-2">
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            data-apply-tracking={id}
            class="inline-flex items-center justify-center gap-2.5 w-full md:w-auto px-7 py-3.5 rounded-full bg-ink text-paper dark:bg-slate-100 dark:text-ink text-[15px] font-semibold hover:opacity-85 transition-opacity whitespace-nowrap"
          >
            Apply at {company}
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17L17 7" /><path d="M7 7h10v10" />
            </svg>
          </a>
          <p class="text-[11px] text-slate-400 dark:text-slate-500 md:text-right">
            Verified listing on {atsDomain}
          </p>
        </div>
      </header>

      {isVeryStale && (
        <div class="animate-fade-in stagger-2 flex items-start gap-2 mt-6 px-3 py-2.5 rounded-lg bg-amber-50 dark:bg-amber-950/30 border border-amber-200 dark:border-amber-800/40">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="shrink-0 mt-0.5 text-amber-500" aria-hidden="true">
            <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>
          </svg>
          <p class="text-xs text-amber-700 dark:text-amber-300 leading-relaxed">
            This listing is 30+ days old. Verify it's still open before applying — roles at this age are sometimes filled or quietly closed.
          </p>
        </div>
      )}

      <div class="grid lg:grid-cols-[minmax(0,1fr)_320px] gap-12 lg:gap-16 pt-10">

        <!-- Main column: the role itself -->
        <article id="about" class="scroll-mt-20 animate-fade-up stagger-2 min-w-0">
          {details ? (
            <>
              <div class="job-desc" set:html={details.descriptionHtml} />
              <p class="mt-8 text-[11px] text-slate-400 dark:text-slate-500">
                Pulled from {company}'s listing on {atsDomain} · last checked {details.fetchedAt}. The listing itself is the source of truth.
              </p>
            </>
          ) : (
            <p class="text-[15px] text-ink-soft dark:text-slate-300 leading-relaxed max-w-prose">
              {company}'s listing doesn't allow automated preview — the full description, requirements, and process live on their official posting.
            </p>
          )}

          <div class="border-t border-line dark:border-slate-700/50 mt-10 pt-8">
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              data-apply-tracking={id}
              class="inline-flex items-center gap-2.5 px-8 py-4 rounded-full bg-ink text-paper dark:bg-slate-100 dark:text-ink text-base font-semibold hover:opacity-85 transition-opacity"
            >
              Apply at {company}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M7 17L17 7" /><path d="M7 7h10v10" />
              </svg>
            </a>
            <a
              href={reportUrl}
              class="flex w-fit mt-8 items-center gap-1.5 text-xs text-slate-400 dark:text-slate-500 hover:text-ink dark:hover:text-slate-300 transition-colors"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <path d="m10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
              Looks like this job is closed? Flag it.
            </a>

            <!-- Feedback prompt: shown by JS after 14+ days from first apply click -->
            <div id="feedback-prompt" class="hidden mt-8 p-4 rounded-xl border border-line dark:border-slate-700 bg-[#FAFAF9] dark:bg-surface-card">
              <p class="text-sm font-semibold text-ink dark:text-slate-100 mb-1">How's the process at {company}?</p>
              <p class="text-xs text-muted dark:text-slate-400 mb-3 leading-relaxed">Looks like you applied a while back. Your experience helps other designers know what to expect.</p>
              <div class="flex items-center gap-3 flex-wrap">
                <a
                  href={feedbackUrl}
                  class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-ink text-paper dark:bg-slate-100 dark:text-ink text-sm font-semibold hover:opacity-85 transition-opacity"
                >
                  Share your experience
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
                </a>
                <button type="button" id="dismiss-feedback-prompt" class="text-xs text-muted dark:text-slate-400 hover:text-ink dark:hover:text-slate-300 transition-colors">
                  Not now
                </button>
              </div>
            </div>
          </div>
        </article>

        <!-- Right rail on desktop; collapsible sections above the description on mobile -->
        <aside class="-order-1 lg:order-none lg:pt-1">
          <div class="lg:sticky lg:top-24 space-y-3 lg:space-y-0 lg:divide-y lg:divide-line lg:dark:divide-slate-700/50">

            {contacts.length > 0 && (
              <details id="s-contact" class="scroll-mt-20 rail-section group animate-fade-up stagger-2" open data-default-open>
                <summary class="rail-summary">
                  <span class="flex items-center gap-1.5">
                    <h2 class="font-mono text-[11px] leading-none uppercase tracking-[0.14em] text-muted dark:text-slate-500">Who to contact</h2>
                    <span class="rail-tip" tabindex="0" role="note" aria-label="Our best guess from public profiles — they look involved in hiring, but we could be wrong.">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                      <span class="tip-body">Our best guess from public profiles — they look involved in hiring, but we could be wrong.</span>
                    </span>
                  </span>
                  <svg class="rail-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
                </summary>
                <div class="rail-content">
                <ul class="space-y-3">
                  {contacts.map(c => (
                    <li>
                      <a
                        href={c.linkedinUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group flex items-start justify-between gap-3"
                      >
                        <span class="min-w-0">
                          <span class="block text-sm text-ink dark:text-slate-100 group-hover:underline underline-offset-2">{c.name}</span>
                          {c.title && c.title.toLowerCase() !== (roleLabel[c.role] || '').toLowerCase() && (
                            <span class="block text-xs text-muted dark:text-slate-400 leading-snug mt-0.5 line-clamp-2">{c.title}</span>
                          )}
                        </span>
                        <span class="shrink-0 inline-flex items-center gap-1 font-mono text-[10px] uppercase tracking-[0.1em] text-muted dark:text-slate-500 mt-0.5">
                          {roleLabel[c.role] || c.role}
                          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M7 17L17 7" /><path d="M7 7h10v10" />
                          </svg>
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
                </div>
              </details>
            )}

            <details id="s-process" class="scroll-mt-20 rail-section group animate-fade-up stagger-2" open data-default-open>
              <summary class="rail-summary">
                <span class="flex items-center gap-1.5">
                  <h2 class="font-mono text-[11px] leading-none uppercase tracking-[0.14em] text-muted dark:text-slate-500">Candidate experience</h2>
                  {interviewProcess && (
                    <span class="rail-tip" tabindex="0" role="note" aria-label="Gathered from community reports of past interviews — processes change and details may be off.">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                      <span class="tip-body">Gathered from community reports of past interviews — processes change and details may be off.</span>
                    </span>
                  )}
                </span>
                <svg class="rail-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
              </summary>
              <div class="rail-content">
              {gradeResult && !gradeResult.hasEnoughData && gradeResult.reportCount > 0 && (
                <p class="text-[11px] font-mono text-muted dark:text-slate-500 mb-3">
                  {gradeResult.reportCount} report{gradeResult.reportCount !== 1 ? 's' : ''} — grade appears at {MIN_REPORTS_FOR_GRADE}
                </p>
              )}
              {gradeResult?.hasEnoughData && (
                <button
                  type="button"
                  data-open-grade-modal
                  aria-haspopup="dialog"
                  aria-label={`Candidate experience grade ${gradeResult.grade}, ${gradeResult.score} out of 100 from ${gradeResult.reportCount} reports — see breakdown`}
                  class="group/grade w-full flex items-center gap-3 mb-6 pb-5 border-b border-line dark:border-slate-700/50 text-left cursor-pointer"
                >
                  <span class={`grade-chip-lg grade-chip-${gradeColorClass}`} aria-hidden="true">{gradeResult.grade}</span>
                  <span class="flex-1 min-w-0 text-sm text-ink dark:text-slate-100">
                    {gradeResult.score}/100
                    <span class="text-muted dark:text-slate-500"> · {gradeResult.reportCount} reports</span>
                  </span>
                  <svg class="shrink-0 text-muted dark:text-slate-500 group-hover/grade:text-ink dark:group-hover/grade:text-slate-200 transition-colors" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                </button>
              )}
              {interviewProcess ? (
                <div>
                  {(interviewProcess.rounds || interviewProcess.timeline) && (
                    <p class="text-sm font-medium text-ink dark:text-slate-100 mb-4">
                      {interviewProcess.rounds && interviewProcess.timeline
                        ? `${interviewProcess.rounds} rounds over ${interviewProcess.timeline}`
                        : interviewProcess.rounds
                        ? `${interviewProcess.rounds} rounds`
                        : `Typically ${interviewProcess.timeline}`}
                    </p>
                  )}

                  {interviewProcess.roundTypes && interviewProcess.roundTypes.length > 0 && (
                    <ol>
                      {interviewProcess.roundTypes.map((rt: string, i: number) => (
                        <li class="relative flex items-center gap-3 pb-3.5 last:pb-0">
                          {i < interviewProcess.roundTypes.length - 1 && (
                            <span class="absolute left-[9px] top-[21px] bottom-0.5 w-px bg-line dark:bg-slate-700/60" aria-hidden="true"></span>
                          )}
                          <span class="w-[19px] h-[19px] shrink-0 rounded-full border border-line dark:border-slate-700 bg-paper dark:bg-transparent font-mono text-[10px] text-muted dark:text-slate-400 inline-flex items-center justify-center leading-none">{i + 1}</span>
                          <span class="text-sm text-ink dark:text-slate-100">{sentence(rt)}</span>
                        </li>
                      ))}
                    </ol>
                  )}

                  {(interviewProcess.hasAssessment !== undefined || typeof interviewProcess.gotFeedback === 'boolean') && (
                    <div class="mt-5 flex flex-wrap gap-1.5">
                      {interviewProcess.hasAssessment !== undefined && (
                        <span class="px-3 py-1 rounded-full border border-line dark:border-slate-700 text-xs text-ink-soft dark:text-slate-300 font-mono">
                          {interviewProcess.hasAssessment
                            ? sentence(interviewProcess.assessmentType || 'take-home exercise')
                            : 'No take-home reported'}
                        </span>
                      )}
                      {typeof interviewProcess.gotFeedback === 'boolean' && (
                        <span class:list={[
                          "inline-flex items-center gap-1.5 px-3 py-1 rounded-full border text-xs font-mono",
                          interviewProcess.gotFeedback
                            ? 'border-line dark:border-slate-700 text-ink-soft dark:text-slate-300'
