<script>
  // Sticky section nav: slides in once the page header scrolls out of view.
  const sectionNav = document.getElementById('section-nav');
  const overviewEl = document.getElementById('overview');
  if (sectionNav && overviewEl) {
    // Cover the site header exactly — a shorter bar lets the header's own
    // bottom border peek out underneath, reading as a double divider
    const siteHeader = document.querySelector<HTMLElement>('header[role="banner"]');
    const sizeNav = () => { sectionNav.style.height = `${siteHeader?.offsetHeight || 57}px`; };
    sizeNav();
    window.addEventListener('resize', sizeNav, { passive: true });

    new IntersectionObserver(([entry]) => {
      const show = !entry.isIntersecting && entry.boundingClientRect.top < 0;
      sectionNav.classList.toggle('section-nav--visible', show);
    }, { threshold: 0 }).observe(overviewEl);

    // Listings vary too much for section anchors to behave predictably
    // (sticky rail, optional sections, wildly different description lengths).
    // The bar is context + action: title returns to top, Apply stays at hand.
    document.getElementById('nav-to-top')?.addEventListener('click', () => {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
    });
  }

  // Grade breakdown dialog
  const gradeModal = document.getElementById('grade-modal') as HTMLDialogElement | null;
  if (gradeModal) {
    document.querySelectorAll('[data-open-grade-modal]').forEach(b =>
      b.addEventListener('click', () => gradeModal.showModal()));
    document.querySelectorAll('[data-close-grade-modal]').forEach(b =>
      b.addEventListener('click', () => gradeModal.close()));
    gradeModal.addEventListener('click', e => {
      if (e.target === gradeModal) gradeModal.close();
    });
  }

  // Rail sections: open panel on desktop, accordions on mobile.
  // SSR renders everything open (desktop-first, no-JS safe); on mobile we
  // collapse all but the data-default-open section.
  const railSections = document.querySelectorAll('details.rail-section');
  const railMq = window.matchMedia('(min-width: 1024px)');
  const applyRailState = () => {
    railSections.forEach(d => {
      (d as HTMLDetailsElement).open = railMq.matches || d.hasAttribute('data-default-open');
    });
  };
  applyRailState();
  railMq.addEventListener('change', applyRailState);

  // "Read all N reports" dialog
  const anecdotesModal = document.getElementById('anecdotes-modal') as HTMLDialogElement | null;
  if (anecdotesModal) {
    document.querySelectorAll('[data-open-anecdotes-modal]').forEach(b =>
      b.addEventListener('click', () => anecdotesModal.showModal()));
    document.querySelectorAll('[data-close-anecdotes-modal]').forEach(b =>
      b.addEventListener('click', () => anecdotesModal.close()));
    // Footer CTA hands off to the process modal by clicking a trigger that
    // ProcessModal's inline script bound at parse time (this dialog renders
    // after that script runs, so its own buttons can't be bound there).
    document.querySelectorAll('[data-anecdotes-to-process]').forEach(b =>
      b.addEventListener('click', () => {
        anecdotesModal.close();
        document.querySelector<HTMLButtonElement>('button[data-open-process-modal]')?.click();
      }));
    anecdotesModal.addEventListener('click', (e) => {
      if (e.target === anecdotesModal) anecdotesModal.close();
    });
    // Sort toggle (only rendered with 5+ reports): list is SSR'd newest
    // first, so each click just reverses the DOM order.
    const sortBtn = document.getElementById('anecdote-sort');
    const list = document.getElementById('anecdotes-list');
    sortBtn?.addEventListener('click', () => {
      const newest = sortBtn.getAttribute('aria-pressed') === 'false';
      [...list!.children].reverse().forEach(li => list!.appendChild(li));
      sortBtn.setAttribute('aria-pressed', String(newest));
      sortBtn.querySelector('span')!.textContent = newest ? 'Oldest first' : 'Newest first';
      list!.parentElement!.scrollTop = 0;
    });
  }
</script>

