  <script define:vars={{ jobId: id }}>
    // Apply tracking: record first click date in localStorage
    const applyKey = `dj-apply-${jobId}`;
    const applyData = JSON.parse(localStorage.getItem(applyKey) || 'null');

    document.querySelectorAll('[data-apply-tracking]').forEach(btn => {
      btn.addEventListener('click', () => {
        const now = Date.now();
        const existing = JSON.parse(localStorage.getItem(applyKey) || 'null');
        localStorage.setItem(applyKey, JSON.stringify({
          firstAt: existing?.firstAt ?? now,
          count: (existing?.count ?? 0) + 1,
          dismissed: existing?.dismissed ?? false,
        }));
      });
    });

    // Show feedback prompt if applied 14+ days ago and not dismissed
    const FOURTEEN_DAYS_MS = 14 * 24 * 60 * 60 * 1000;
    if (applyData?.firstAt && !applyData?.dismissed && Date.now() - applyData.firstAt >= FOURTEEN_DAYS_MS) {
      document.getElementById('feedback-prompt')?.classList.remove('hidden');
    }

    document.getElementById('dismiss-feedback-prompt')?.addEventListener('click', () => {
      document.getElementById('feedback-prompt')?.classList.add('hidden');
      const existing = JSON.parse(localStorage.getItem(applyKey) || 'null');
      localStorage.setItem(applyKey, JSON.stringify({ ...existing, dismissed: true }));
    });
  </script>

